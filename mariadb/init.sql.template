CREATE DATABASE IF NOT EXISTS ${MYSQL_DATABASE_COREPROTECT};

CREATE USER IF NOT EXISTS 'coreprotect'@'%' IDENTIFIED BY '${MYSQL_PASSWORD_COREPROTECT}';
CREATE USER IF NOT EXISTS 'grafana'@'%' IDENTIFIED BY '${MYSQL_PASSWORD_GRAFANA}';

GRANT SELECT, INSERT, UPDATE, DELETE, CREATE, DROP, ALTER, INDEX, REFERENCES ON ${MYSQL_DATABASE_COREPROTECT}.* TO 'coreprotect'@'%';
GRANT SELECT ON ${MYSQL_DATABASE_COREPROTECT}.* TO 'grafana'@'%';

FLUSH PRIVILEGES;
