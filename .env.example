# Database configuration
DB_HOST=mariadb
DB_PORT=3306

# Resource limits for Minecraft server
MINECRAFT_MEMORY_LIMIT=5g
MINECRAFT_CPU_LIMIT=4

# Network configuration
JSON_EXPORTER_BIND_IP=127.0.0.1
JSON_EXPORTER_PORT=7979
BLACKBOX_EXPORTER_BIND_IP=127.0.0.1
BLACKBOX_EXPORTER_PORT=9115
NODE_EXPORTER_PORT=9100

# Health check configuration
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=5s
HEALTHCHECK_RETRIES=3
HEALTHCHECK_START_PERIOD=10s

# MariaDB database names
MYSQL_DATABASE_COREPROTECT=coreprotect
MYSQL_DATABASE_DISCORDSRV=discordsrv

# MariaDB usernames
MYSQL_USERNAME_DISCORDSRV=discord
MYSQL_USERNAME_VDAUTH=vdauth

# Velocity configuration
VELOCITY_FORWARDING_SECRET=your-base64-encoded-secret-here

# DiscordSRV configuration
DISCORDSRV_BOT_TOKEN=your-discord-bot-token-here

# MariaDB user passwords (replace with your own secure passwords)
MYSQL_PASSWORD_COREPROTECT=your_secure_password_here
MYSQL_PASSWORD_DISCORDSRV=your_secure_password_here
MYSQL_PASSWORD_GRAFANA=your_secure_password_here
